# ============================================================
# Environment Variables - Backend GMAO
# Copy this file to .env and fill in the values
# ============================================================

# --- Docker Registry ---
DOCKER_REGISTRY=ghcr.io
DOCKER_IMAGE_PREFIX=Allabira-Abdoul/gmao-backend
IMAGE_TAG=latest

# --- PostgreSQL ---
POSTGRES_USER=gmao_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=gmao_db

# --- Consul ---
CONSUL_HOST=consul
CONSUL_PORT=8500
